# Coinbase CDP API credentials
# Sign up at https://cdp.coinbase.com
# Required for the x402 facilitator (payment verification + settlement)
# Free tier: 1,000 transactions/month
CDP_API_KEY_ID=your-cdp-api-key-id
CDP_API_KEY_SECRET=your-cdp-api-key-secret

# Anthropic API key
# Required for Claude Opus 4.7 calls on /contemplate and /forest
# Without this, the 402 negotiation still works locally but paid calls return 500
ANTHROPIC_API_KEY=sk-ant-your-key-here
